## escalier routable pour piéton
highway=steps [0x13 default_name="escalier" road_class=0 road_speed=0 resolution 24]

highway=* & trail_visibility=no {name 
'${name}, sentier / ${note} invisible'|
'${name}, sentier invisible'|
'sentier ${note} invisible'|
'sentier invisible'
} [0x11f19 default_name="invisible" resolution 23]
disused:highway=* {name 
'${name}, ${note} existe plus'|
'${name} existe plus'|
'${note} existe plus'
} [0x11f19  default_name="existe plus" resolution 23]

## sentiers
highway=path {name 
'${name}, sentier / ${note}'|
'${name}, sentier'|
'sentier ${note}'|
'sentier'
}

highway=path {name '${name}, ${chemin}'|'${chemin}'} [0x16 road_class=0 road_speed=0 resolution 22 continue] #jusqu'a resolution 24 pour routage !
highway=path {name '${name}, ${chemin}'|'${chemin}'} [0x12d1e resolution 24]

(highway=footway|highway=pedestrian) & (location=roof|level='-1'|tunnel=building_passage) [0x0d road_class=0 road_speed=0 resolution 24]
