highway=footway [0x12d1e default_name="piéton" resolution 24]

highway=pedestrian & (area!=yes|is_closed()=false|mkgmap:mp_created=false) [0x0e default_name="pedestre" road_class=0 road_speed=0 resolution 24 ]

